{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgorIA LLM batch output",
  "type": "object",
  "required": ["items"],
  "properties": {
    "schema_version": {"type": "string"},
    "batch_id": {"type": "string"},
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "task", "source_id", "output"],
        "properties": {
          "id": {"type": "string"},
          "task": {"type": "string", "enum": ["classify_subject", "summarize_question_and_answer"]},
          "source_id": {"type": "string"},
          "status": {"type": "string", "enum": ["ok", "error", "skipped"]},
          "output": {"type": "object"},
          "error": {"type": "string"}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
