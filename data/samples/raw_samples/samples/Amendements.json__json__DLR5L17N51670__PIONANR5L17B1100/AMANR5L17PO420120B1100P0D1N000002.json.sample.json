        "contenuAuteur": {
          "dispositif": "<p style=\"text-align: justify;\">La propagande ou la publicit&#x00E9; en faveur de l&#x2019;aide &#x00E0; mourir, par assistance au suicide ou par euthanasie, est r&#x00E9;prim&#x00E9;e par l&#x2019;article&nbsp;223&#x2011;14 du code p&#x00E9;nal.</p>",
          "avantAppel": {
            "@xmlns:xsi": "http://www.w3.org/2001/XMLSchema-instance",
            "@xsi:nil": "true"
          },
          "exposeSommaire": "<p style=\"text-align: justify;\">Vu la promotion du suicide assist&#x00E9; et de l&#x2019;euthanasie, qui est faite dans certains pays, en particulier par des associations, il importe d&#x2019;emp&#x00EA;cher de telles d&#x00E9;rives.</p><p style=\"text-align: justify;\">Tel est le sens de cet amendement.</p>",
          "annexeExposeSommaire": {
            "@xmlns:xsi": "http://www.w3.org/2001/XMLSchema-instance",
            "@xsi:nil": "true"
          }
