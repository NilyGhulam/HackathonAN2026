        "contenuAuteur": {
          "dispositif": "<p style=\"text-align: justify;\">Au titre de la proposition de loi, substituer aux mots&nbsp;:</p><p style=\"text-align: justify;\">&#x00AB;&nbsp;aide &#x00E0; mourir&nbsp;&#x00BB;</p><p style=\"text-align: justify;\">les mots&nbsp;:</p><p style=\"text-align: justify;\">&#x00AB;&nbsp;euthanasie et au suicide assist&#x00E9;&nbsp;&#x00BB;.</p>",
          "avantAppel": {
            "@xmlns:xsi": "http://www.w3.org/2001/XMLSchema-instance",
            "@xsi:nil": "true"
          },
          "exposeSommaire": "<p style=\"text-align: justify;\">Cette proposition de loi vise &#x00E0; l&#x00E9;galiser le suicide assist&#x00E9; et l&#x2019;euthanasie. M&#x00EA;me si, comme l&#x2019;a soulign&#x00E9; la pr&#x00E9;sidente de la Soci&#x00E9;t&#x00E9; Fran&#x00E7;aise des Soins Palliatifs (SFAP), &#x00AB;&nbsp;le geste est (&#x2026;) peut-&#x00EA;tre trop difficile pour pouvoir &#x00EA;tre nomm&#x00E9; et assum&#x00E9; politiquement.&nbsp;&#x00BB;, il est essentiel d&#x2019;indiquer clairement les objectifs de ce texte. Cet amendement vise donc &#x00E0; faire preuve d&#x2019;honn&#x00EA;tet&#x00E9; et &#x00E0; ne pas dissimuler la r&#x00E9;alit&#x00E9; des actes qui seront pos&#x00E9;s afin de provoquer la fin de la vie, &#x00E0; savoir l&#x2019;administration par un praticien d&#x2019;un m&#x00E9;dicament qui entra&#x00EE;ne le d&#x00E9;c&#x00E8;s du malade, ou la remise par un praticien d&#x2019;un m&#x00E9;dicament que le malade peut s&#x2019;autoadministrer pour mourir.</p>",
          "annexeExposeSommaire": {
            "@xmlns:xsi": "http://www.w3.org/2001/XMLSchema-instance",
            "@xsi:nil": "true"
          }
        }
      },
