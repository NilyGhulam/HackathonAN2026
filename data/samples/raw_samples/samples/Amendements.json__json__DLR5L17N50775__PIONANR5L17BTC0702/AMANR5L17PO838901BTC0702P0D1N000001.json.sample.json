        },
        "contenuAuteur": {
          "dispositif": "<p style=\"text-align: justify;\">Apr&#x00E8;s le premier alin&#x00E9;a du I de l&#x2019;article L.&nbsp;2324&#x2011;2 du code de la sant&#x00E9; publique, sont ins&#x00E9;r&#x00E9;s deux alin&#x00E9;as ainsi r&#x00E9;dig&#x00E9;s&nbsp;:</p><p style=\"text-align: justify;\">&#x00AB;&nbsp;Les contr&#x00F4;les des &#x00E9;tablissements d&#x2019;accueil du jeune enfant sont r&#x00E9;alis&#x00E9;s p&#x00E9;riodiquement conform&#x00E9;ment &#x00E0; la grille nationale de contr&#x00F4;le des &#x00E9;tablissements d&#x2019;accueil du jeune enfant &#x00E9;tablie par arr&#x00EA;t&#x00E9; du ministre charg&#x00E9; de la famille et fixant notamment la liste exhaustive des points de contr&#x00F4;le et de leurs modalit&#x00E9;s de contr&#x00F4;le.</p><p style=\"text-align: justify;\">&#x00AB;&nbsp;Les r&#x00E9;sultats de ces contr&#x00F4;les sont publi&#x00E9;s.&nbsp;&#x00BB;</p><p style=\"text-align: justify;\">&nbsp;</p>",
          "avantAppel": {
            "@xmlns:xsi": "http://www.w3.org/2001/XMLSchema-instance",
            "@xsi:nil": "true"
          },
          "exposeSommaire": "<p>Cet amendement vise &#x00E0; instaurer un cadre national homog&#x00E8;ne de contr&#x00F4;le de tous les EAJE.</p>",
          "annexeExposeSommaire": {
            "@xmlns:xsi": "http://www.w3.org/2001/XMLSchema-instance",
