        },
        "contenuAuteur": {
          "dispositif": "<p style=\"text-align: justify;\">Substituer &#x00E0; l&#x2019;alin&#x00E9;a&nbsp;14&nbsp;les trois&nbsp;alin&#x00E9;as suivants&nbsp;:</p><p style=\"text-align: justify;\">&#x00AB;&nbsp;Le III est ainsi r&#x00E9;dig&#x00E9;&nbsp;:</p><p style=\"text-align: justify;\">&#x00AB;&nbsp;Le prix global de la liste mentionn&#x00E9;e au I, tel qu&#x2019;il est pratiqu&#x00E9;, est affich&#x00E9; en application de l&#x2019;article L.&nbsp;112&#x2011;1 du code de la consommation, de mani&#x00E8;re lisible et visible &#x00E0; l&#x2019;entr&#x00E9;e de la surface de vente par le moyen d&#x2019;un support d&#x2019;une superficie au moins &#x00E9;gal &#x00E0; un m&#x00E8;tre carr&#x00E9; d&#x2019;une liste limitative de produits de consommation courante.</p><p style=\"text-align: justify;\">&#x00AB;&nbsp;Pour chaque produit composant la liste mentionn&#x00E9;e au I et expos&#x00E9;e &#x00E0; la vente au d&#x00E9;tail, un balisage d&#x2019;identification est appos&#x00E9; de mani&#x00E8;re permanente &#x00E0; proximit&#x00E9; imm&#x00E9;diate de celui-ci.&nbsp;&#x00BB;</p>",
          "avantAppel": {
            "@xmlns:xsi": "http://www.w3.org/2001/XMLSchema-instance",
            "@xsi:nil": "true"
          },
          "exposeSommaire": "<p>Cette nouvelle r&#x00E9;daction permet&nbsp; de pr&#x00E9;ciser les modalit&#x00E9;s d'affichage des prix : caract&#x00E8;re, position, moyen et dimension, pour une meilleure information du consommateur.</p>",
          "annexeExposeSommaire": {
            "@xmlns:xsi": "http://www.w3.org/2001/XMLSchema-instance",
            "@xsi:nil": "true"
          }
        }
