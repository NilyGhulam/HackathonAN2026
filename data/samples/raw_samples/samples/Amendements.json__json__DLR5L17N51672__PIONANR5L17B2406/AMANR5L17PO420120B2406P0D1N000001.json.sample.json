        "contenuAuteur": {
          "dispositif": "<p>Supprimer l'alin&#x00E9;a 8.</p>",
          "avantAppel": {
            "@xmlns:xsi": "http://www.w3.org/2001/XMLSchema-instance",
            "@xsi:nil": "true"
          },
          "exposeSommaire": "<p style=\"text-align: justify;\">Cet amendement des d&#x00E9;put&#x00E9;s socialistes et apparent&#x00E9;s vise &#x00E0;&nbsp;supprimer la mention que l&#x2019;accompagnement et les soins palliatifs ne visent ni &#x00E0; h&#x00E2;ter, ni &#x00E0; diff&#x00E9;rer la survenue de la mort.</p><p style=\"text-align: justify;\">L&#x2019;alin&#x00E9;a qu&#x2019;il est propos&#x00E9; ici de supprimer a &#x00E9;t&#x00E9; ajout&#x00E9; par un amendement du groupe EPR en Commission des Affaires sociales, supprim&#x00E9; en s&#x00E9;ance en 1<sup>&#x00E8;re</sup> lecture, puis rajout&#x00E9; au S&#x00E9;nat.</p><p style=\"text-align: justify;\">Il revient &#x00E0;&nbsp;introduire dans la loi&nbsp;le contenu m&#x00E9;dical de l&#x2019;accompagnement et des soins palliatif, ce qui n&#x2019;est pas le r&#x00F4;le du droit.</p><p style=\"text-align: justify;\">Il est donc propos&#x00E9; de supprimer cet alin&#x00E9;a.&nbsp;</p>",
          "annexeExposeSommaire": {
            "@xmlns:xsi": "http://www.w3.org/2001/XMLSchema-instance",
            "@xsi:nil": "true"
          }
        }
      },
