        "contenuAuteur": {
          "dispositif": "<p style=\"text-align: justify;\">&#x00C0; l&#x2019;alin&#x00E9;a&nbsp;2, substituer au mot&nbsp;:</p><p style=\"text-align: justify;\">&#x00AB;&nbsp;salari&#x00E9;s&nbsp;&#x00BB;</p><p style=\"text-align: justify;\">le mot&nbsp;:</p><p style=\"text-align: justify;\">&#x00AB;&nbsp;travailleurs&nbsp;&#x00BB;.</p>",
          "avantAppel": {
            "@xmlns:xsi": "http://www.w3.org/2001/XMLSchema-instance",
            "@xsi:nil": "true"
          },
          "exposeSommaire": "<p style=\"text-align: justify;\">Cet amendement des d&#x00E9;put&#x00E9;s socialistes et apparent&#x00E9;s vise &#x00E0; am&#x00E9;liorer la r&#x00E9;daction de l&#x2019;article unique de la proposition de loi en &#x00E9;tendant l&#x2019;interdiction de travail de nuit aux &#x00AB;&nbsp;<i>travailleurs</i>&nbsp;&#x00BB; et non seulement aux &#x00AB;&nbsp;<i>salari&#x00E9;s</i>&nbsp;&#x00BB;.</p><p style=\"text-align: justify;\">Il y a en effet de nombreux travailleurs des m&#x00E9;tiers du nettoyage qui n'exercent pas en salariat (<i>via</i> un contrat d&#x2019;int&#x00E9;rim, en tant que travailleur ind&#x00E9;pendant, etc.)</p><p style=\"text-align: justify;\">Il est donc propos&#x00E9; ici de faire b&#x00E9;n&#x00E9;ficier ces travailleurs non-salari&#x00E9;s de l&#x2019;interdiction des horaires de nuit pr&#x00E9;vue par la proposition de loi.</p><p style=\"text-align: justify;\">Tel est l'objet du pr&#x00E9;sent amendement.</p>",
          "annexeExposeSommaire": {
            "@xmlns:xsi": "http://www.w3.org/2001/XMLSchema-instance",
            "@xsi:nil": "true"
          }
        }
      },
