        "contenuAuteur": {
          "dispositif": "<p style=\"text-align: justify;\">I.&nbsp;&#x2013;&nbsp;&#x00C0; l&#x2019;alin&#x00E9;a&nbsp;3, substituer aux mots&nbsp;:</p><p style=\"text-align: justify;\">&#x00AB;&nbsp;r&#x00E9;ception de cette demande&nbsp;&#x00BB;</p><p style=\"text-align: justify;\">les mots&nbsp;:</p><p style=\"text-align: justify;\">&#x00AB;&nbsp;date de la d&#x00E9;cision de r&#x00E9;siliation&nbsp;&#x00BB;.</p><p style=\"text-align: justify;\">II.&nbsp;&#x2013;&nbsp;Au m&#x00EA;me alin&#x00E9;a, substituer aux mots&nbsp;:</p><p style=\"text-align: justify;\">&#x00AB;&nbsp;la d&#x00E9;cision de r&#x00E9;siliation&nbsp;&#x00BB;</p><p style=\"text-align: justify;\">les mots&nbsp;:</p><p style=\"text-align: justify;\">&#x00AB;&nbsp;sa d&#x00E9;cision&nbsp;&#x00BB;.</p>",
          "avantAppel": {
            "@xmlns:xsi": "http://www.w3.org/2001/XMLSchema-instance",
            "@xsi:nil": "true"
          },
          "exposeSommaire": "<p style=\"text-align: justify;\">Par cet amendement r&#x00E9;dactionnel, les d&#x00E9;put&#x00E9;s du groupe LFI-NFP proposent de clarifier la r&#x00E9;daction de l&#x2019;article pour assurer que la motivation de fermeture unilat&#x00E9;rale de compte soit fournie, de fa&#x00E7;on automatique, par l&#x2019;&#x00E9;tablissement bancaire, sans que le client ait besoin d&#x2019;en faire express&#x00E9;ment la demande.</p>",
          "annexeExposeSommaire": {
            "@xmlns:xsi": "http://www.w3.org/2001/XMLSchema-instance",
            "@xsi:nil": "true"
          }
