        "contenuAuteur": {
          "dispositif": "<p style=\"text-align: justify;\">&#x00C0;&nbsp;la derni&#x00E8;re phrase de&nbsp;l&#x2019;alin&#x00E9;a&nbsp;5, substituer aux mots&nbsp;:</p><p style=\"text-align: justify;\">&#x00AB;&nbsp;de r&#x00E9;vision&nbsp;&#x00BB;</p><p style=\"text-align: justify;\">les mots&nbsp;:&nbsp;</p><p style=\"text-align: justify;\">&#x00AB;&nbsp;pour s&#x00E9;curiser les accouchements r&#x00E9;alis&#x00E9;s, am&#x00E9;liorer la sant&#x00E9; des nouveaux-n&#x00E9;s et r&#x00E9;viser&nbsp;&#x00BB;.</p>",
          "avantAppel": {
            "@xmlns:xsi": "http://www.w3.org/2001/XMLSchema-instance",
            "@xsi:nil": "true"
          },
          "exposeSommaire": "<p style=\"text-align: justify;\">Cet amendement des d&#x00E9;put&#x00E9;s socialistes et apparent&#x00E9;s vise &#x00E0;&nbsp;s&#x2019;assurer que les le&#x00E7;ons tir&#x00E9;es de la pause des fermetures de maternit&#x00E9; pendant 3 ans&nbsp;aient bien une traduction en termes d&#x2019;am&#x00E9;lioration de la s&#x00E9;curit&#x00E9; des accouchements r&#x00E9;alis&#x00E9;s et de la sant&#x00E9; des nouveaux n&#x00E9;s.</p>",
          "annexeExposeSommaire": {
            "@xmlns:xsi": "http://www.w3.org/2001/XMLSchema-instance",
            "@xsi:nil": "true"
          }
