        "contenuAuteur": {
          "dispositif": "<p style=\"text-align: justify;\">R&#x00E9;tablir cet article&nbsp;dans la r&#x00E9;daction suivante&nbsp;:</p><p style=\"text-align: justify;\">&#x00AB;&nbsp;L&#x2019;article&nbsp;L.&nbsp;211&#x2011;7 du code de la s&#x00E9;curit&#x00E9; int&#x00E9;rieure est ainsi modifi&#x00E9;&nbsp;:</p><p style=\"text-align: justify;\">&#x00AB;&nbsp;1&#x00B0;&nbsp;Le second alin&#x00E9;a est compl&#x00E9;t&#x00E9; par une phrase ainsi r&#x00E9;dig&#x00E9;e&nbsp;:&nbsp;&#x00AB;&nbsp;Les d&#x00E9;cisions prises pour assurer l&#x2019;effectivit&#x00E9; de l&#x2019;interdiction sont ex&#x00E9;cutoires d&#x2019;office.&nbsp;&#x00BB;&nbsp;;</p><p style=\"text-align: justify;\">&#x00AB;&nbsp;2&#x00B0;&nbsp;Il est ajout&#x00E9; un alin&#x00E9;a ainsi r&#x00E9;dig&#x00E9;&nbsp;:</p><p style=\"text-align: justify;\">&#x00AB;&nbsp;Le deuxi&#x00E8;me alin&#x00E9;a de l&#x2019;article&nbsp;L.&nbsp;211&#x2011;11 est applicable, y compris lorsque le rassemblement musical n&#x2019;a pas &#x00E9;t&#x00E9; d&#x00E9;clar&#x00E9;.&nbsp;&#x00BB;</p>",
          "avantAppel": {
            "@xmlns:xsi": "http://www.w3.org/2001/XMLSchema-instance",
            "@xsi:nil": "true"
          },
          "exposeSommaire": "<p>Le pr&#x00E9;sent amendement vise &#x00E0; r&#x00E9;tablir l&#x2019;article 2bis renforce les pouvoirs du pr&#x00E9;fet contre les rave parties ill&#x00E9;gales en autorisant l&#x2019;ex&#x00E9;cution forc&#x00E9;e des interdictions et en faisant supporter aux organisateurs les co&#x00FB;ts des interventions publiques de s&#x00E9;curisation</p><p>Cet article&nbsp;a &#x00E9;t&#x00E9; supprim&#x00E9; par la Commission des Lois.</p>",
          "annexeExposeSommaire": {
            "@xmlns:xsi": "http://www.w3.org/2001/XMLSchema-instance",
            "@xsi:nil": "true"
          }
        }
