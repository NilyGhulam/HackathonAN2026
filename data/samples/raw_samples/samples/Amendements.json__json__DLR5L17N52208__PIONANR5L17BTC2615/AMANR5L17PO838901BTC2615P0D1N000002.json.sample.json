        "contenuAuteur": {
          "dispositif": "<p style=\"text-align: justify;\">I.&nbsp;&#x2013;&nbsp;Compl&#x00E9;ter l&#x2019;alin&#x00E9;a&nbsp;3 par les mots&nbsp;:</p><p style=\"text-align: justify;\">&#x00AB;&nbsp;pour des conditions de navigation de r&#x00E9;f&#x00E9;rence donn&#x00E9;es&nbsp;&#x00BB;.</p><p style=\"text-align: justify;\">II.&nbsp;&#x2013;&nbsp;En cons&#x00E9;quence, compl&#x00E9;ter l&#x2019;alin&#x00E9;a&nbsp;4 par les mots&nbsp;:</p><p style=\"text-align: justify;\">&#x00AB;&nbsp;pour des conditions de navigation de r&#x00E9;f&#x00E9;rence donn&#x00E9;es&nbsp;&#x00BB;.</p>",
          "avantAppel": {
            "@xmlns:xsi": "http://www.w3.org/2001/XMLSchema-instance",
            "@xsi:nil": "true"
          },
          "exposeSommaire": "<p style=\"text-align: justify;\">Cet amendement du groupe La France insoumise vise &#x00E0; pr&#x00E9;ciser que les conditions de calcul de la part de propulsion v&#x00E9;lique pour un navire doivent faire l&#x2019;objet d&#x2019;une r&#x00E9;f&#x00E9;rence de navigation.</p><p style=\"text-align: justify;\">En effet, l&#x2019;exploitant d&#x2019;un navire &#x00E0; propulsion v&#x00E9;lique peut d&#x00E9;cider sur une route donn&#x00E9;e de faire varier la part du v&#x00E9;lique qu&#x2019;il utilise, voire ne pas l&#x2019;utiliser du tout. Par ailleurs ce choix de l&#x2019;exploitant peut &#x00E9;galement &#x00EA;tre motiv&#x00E9; par les variations des conditions de vent et de navigation, et les &#x00E9;ventuelles contraintes de temps de trajet.</p><p style=\"text-align: justify;\">Ces particularit&#x00E9;s font la difficult&#x00E9; de la d&#x00E9;finition de la propulsion v&#x00E9;lique, qui porte sur la conception du navire et non pas son usage.</p><p style=\"text-align: justify;\">C&#x2019;est pourquoi il convient a minima de pr&#x00E9;ciser qu&#x2019;une r&#x00E9;f&#x00E9;rence de navigation est n&#x00E9;cessaire, et renvoy&#x00E9;e &#x00E0; d&#x00E9;cret dans l&#x2019;alin&#x00E9;a suivant.</p>",
          "annexeExposeSommaire": {
            "@xmlns:xsi": "http://www.w3.org/2001/XMLSchema-instance",
            "@xsi:nil": "true"
          }
        }
      },
